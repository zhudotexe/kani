event: response.output_text.done
data: {"type":"response.output_text.done","content_index":0,"item_id":"msg_01284b4f743792960069a67e0cdac0819091cc9e84a86d9915","logprobs":[],"output_index":1,"sequence_number":129,"text":"ABRACADABRA\ndef factorial(n: int) -> int:\n    if not isinstance(n, int):\n        raise TypeError(\"n must be an integer\")\n    if n < 0:\n        raise ValueError(\"n must be non-negative\")\n    result = 1\n    for i in range(2, n + 1):\n        result *= i\n    return result\n\n# Example usage:\n# print(factorial(5))  # Output: 120\n\n# If you prefer the standard library:\n# import math\n# math.factorial(5)  # 120"}

event: response.content_part.done
data: {"type":"response.content_part.done","content_index":0,"item_id":"msg_01284b4f743792960069a67e0cdac0819091cc9e84a86d9915","output_index":1,"part":{"type":"output_text","annotations":[],"logprobs":[],"text":"ABRACADABRA\ndef factorial(n: int) -> int:\n    if not isinstance(n, int):\n        raise TypeError(\"n must be an integer\")\n    if n < 0:\n        raise ValueError(\"n must be non-negative\")\n    result = 1\n    for i in range(2, n + 1):\n        result *= i\n    return result\n\n# Example usage:\n# print(factorial(5))  # Output: 120\n\n# If you prefer the standard library:\n# import math\n# math.factorial(5)  # 120"},"sequence_number":130}

event: response.output_item.done
data: {"type":"response.output_item.done","item":{"id":"msg_01284b4f743792960069a67e0cdac0819091cc9e84a86d9915","type":"message","status":"completed","content":[{"type":"output_text","annotations":[],"logprobs":[],"text":"ABRACADABRA\ndef factorial(n: int) -> int:\n    if not isinstance(n, int):\n        raise TypeError(\"n must be an integer\")\n    if n < 0:\n        raise ValueError(\"n must be non-negative\")\n    result = 1\n    for i in range(2, n + 1):\n        result *= i\n    return result\n\n# Example usage:\n# print(factorial(5))  # Output: 120\n\n# If you prefer the standard library:\n# import math\n# math.factorial(5)  # 120"}],"role":"assistant"},"output_index":1,"sequence_number":131}

