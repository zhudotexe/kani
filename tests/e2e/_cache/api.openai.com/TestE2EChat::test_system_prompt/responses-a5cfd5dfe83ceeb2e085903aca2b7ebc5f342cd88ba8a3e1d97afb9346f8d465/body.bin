event: response.output_text.done
data: {"type":"response.output_text.done","content_index":0,"item_id":"msg_011eb59a189e2071006a110c973400819dbb1d36a1e57c3a39","logprobs":[],"output_index":1,"sequence_number":151,"text":"ABRACADABRA\ndef factorial(n: int) -> int:\n    \"\"\"\n    Compute the factorial of a non-negative integer n.\n    Returns 1 for n == 0.\n    Raises:\n        TypeError: if n is not an int\n        ValueError: if n is negative\n    \"\"\"\n    if not isinstance(n, int):\n        raise TypeError(\"n must be an integer\")\n    if n < 0:\n        raise ValueError(\"n must be non-negative\")\n    result = 1\n    for i in range(2, n + 1):\n        result *= i\n    return result\n\n# Example usage:\n# print(factorial(5))  # 120"}

event: response.content_part.done
data: {"type":"response.content_part.done","content_index":0,"item_id":"msg_011eb59a189e2071006a110c973400819dbb1d36a1e57c3a39","output_index":1,"part":{"type":"output_text","annotations":[],"logprobs":[],"text":"ABRACADABRA\ndef factorial(n: int) -> int:\n    \"\"\"\n    Compute the factorial of a non-negative integer n.\n    Returns 1 for n == 0.\n    Raises:\n        TypeError: if n is not an int\n        ValueError: if n is negative\n    \"\"\"\n    if not isinstance(n, int):\n        raise TypeError(\"n must be an integer\")\n    if n < 0:\n        raise ValueError(\"n must be non-negative\")\n    result = 1\n    for i in range(2, n + 1):\n        result *= i\n    return result\n\n# Example usage:\n# print(factorial(5))  # 120"},"sequence_number":152}

