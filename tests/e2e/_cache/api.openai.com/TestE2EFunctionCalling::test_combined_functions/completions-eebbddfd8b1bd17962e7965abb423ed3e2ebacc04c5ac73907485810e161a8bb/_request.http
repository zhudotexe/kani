{"messages":[{"role":"system","content":"You are a weather assistant. Use the provided functions to answer weather questions."},{"role":"user","content":"What's the current weather in Miami and what's the forecast for the next 3 days?"}],"model":"gpt-5-mini","tools":[{"type":"function","function":{"name":"get_forecast","description":"Get the 3-day forecast for a location.","parameters":{"description":"Get the 3-day forecast for a location.","properties":{"location":{"description":"The city and state, e.g. San Francisco, CA","type":"string"}},"required":["location"],"title":"get_forecast","type":"object"}}},{"type":"function","function":{"name":"get_weather","description":"Get the current weather in a given location.","parameters":{"$defs":{"Unit":{"enum":["fahrenheit","celsius"],"title":"Unit","type":"string"}},"description":"Get the current weather in a given location.","properties":{"location":{"description":"The city and state, e.g. San Francisco, CA","type":"string"},"unit":{"$ref":"#/$defs/Unit"}},"required":["location","unit"],"title":"get_weather","type":"object"}}}]}